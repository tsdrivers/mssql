{
  "nodeModulesDir": "auto",
  "workspace": [
    "projects/ts-mssql"
  ],
  "tasks": {
    "test": "deno test --allow-env projects/",
    "test:core": "deno test --allow-env projects/ts-mssql/core/",
    "test:integration": "MSSQL_TEST_ENABLED=1 deno test --allow-env --allow-net --allow-ffi --allow-read projects/test/integration/deno/",
    "docs:api": "deno run -A npm:typedoc",
    "docs:dev": "run/docs",
    "docs:build": "run/docs-build",
    "docs:preview": "npm --prefix docs run preview"
  }
}
